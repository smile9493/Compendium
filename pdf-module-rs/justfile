# ─── PDF Module Workspace Task Runner ───
# Usage: just <recipe> [args]
#   just           → 显示此帮助
#   just build     → 构建所有 crate
#   just check     → 仅类型检查
#   just test pdf-core → 测试指定 crate

default:
    @just --list

# ─── 构建 ──────────────────────────────────────

build:
    cargo build --workspace

build-release:
    cargo build --workspace --release

build-wasm:
    cargo build --release -p pdf-wasm --target wasm32-unknown-unknown --profile wasm-release

wasm-size-check:
    just build-wasm
    @test -f target/wasm32-unknown-unknown/wasm-release/pdf_wasm.wasm
    @ls -lh target/wasm32-unknown-unknown/wasm-release/pdf_wasm.wasm

build-fast:
    cargo build --profile dev-fast

# ─── 检查 ──────────────────────────────────────

check:
    cargo check --workspace --all-targets

check-release:
    cargo check --workspace --all-targets --release

# ─── 基准测试 ──────────────────────────────────

bench:
    cargo bench --workspace

bench-extractor:
    cargo bench -p pdf-core --bench extractor_bench

bench-validator:
    cargo bench -p pdf-core --bench validator_bench

# Save current benchmark results as baseline for comparison
bench-save-baseline:
    cargo bench --workspace -- --save-baseline main

# Compare against saved baseline
bench-compare:
    cargo bench --workspace -- --baseline main

# Open benchmark HTML report
bench-report:
    open target/criterion/report/index.html 2>/dev/null || xdg-open target/criterion/report/index.html

# ─── 测试 ──────────────────────────────────────

test *args:
    cargo test --workspace {{args}}

test-nocapture *args:
    cargo test --workspace -- --nocapture {{args}}

# ─── 格式化 ────────────────────────────────────

fmt:
    cargo fmt --all
    taplo fmt

fmt-check:
    cargo fmt --all -- --check
    taplo fmt --check

# ─── Lint ──────────────────────────────────────

clippy:
    cargo clippy --workspace --all-targets --all-features -- -D warnings

clippy-fix:
    cargo clippy --workspace --all-targets --all-features --fix --allow-dirty

# ─── 文档 ──────────────────────────────────────

doc:
    cargo doc --workspace --no-deps --open

doc-private:
    cargo doc --workspace --document-private-items --no-deps --open

# ─── 审计与安全 ────────────────────────────────

audit:
    cargo deny check advisories licenses bans sources
    cargo audit

deny:
    cargo deny check licenses bans sources advisories

spellcheck:
    typos

# Verify Cargo.toml minimum dependency versions are sufficient
# Requires nightly Rust
minimal-versions:
    cargo +nightly update -Z direct-minimal-versions
    cargo +nightly check --workspace --all-targets

# Verify MSRV compatibility (requires installed msrv toolchain)
msrv-check:
    cargo +1.91.0 check --workspace --all-targets

# ─── 依赖分析 ──────────────────────────────────

deps-tree crate="pdf-core":
    cargo tree -p {{crate}}

deps-duplicates:
    cargo tree --duplicates 2>/dev/null || cargo tree -e no-dev --duplicates

deps-unused:
    cargo +nightly udeps --workspace --all-targets

# ─── CI 快速门禁 ───────────────────────────────

ci:
    cargo fmt --all -- --check
    cargo clippy --workspace --all-targets -- -D warnings
    cargo check --workspace --all-targets
    cargo test --workspace
    cargo deny check licenses bans advisories
    typos

# ─── 工具安装 ──────────────────────────────────

install-tools:
    cargo install cargo-deny cargo-audit typos-cli taplo-cli just cargo-udeps cargo-hack

# ─── Git hooks ─────────────────────────────────
#
# Two approaches are available:
#
#   1. pre-commit (Python) — mature ecosystem, many built-in checks
#      just install-hooks
#
#   2. cargo-husky (Rust-native) — no Python dependency, hooks in
#      .cargo-husky/hooks/, auto-installed on first cargo test
#      just install-husky

# Install pre-commit hooks (requires Python + pip)
install-hooks:
    pip install pre-commit
    pre-commit install
    pre-commit install --hook-type pre-push
    @echo "✓ Hooks installed: pre-commit + pre-push"

run-hooks:
    pre-commit run --all-files

# Install cargo-husky hooks (Rust-native, no Python required)
# Hooks auto-install on first `cargo test`; this just triggers it.
install-husky:
    cargo test --no-run -p pdf-core
    @echo "✓ cargo-husky hooks installed (via .cargo-husky/hooks/)"

# Remove all git hooks
uninstall-hooks:
    pre-commit uninstall 2>/dev/null; true
    pre-commit uninstall --hook-type pre-push 2>/dev/null; true
    rm -f .git/hooks/pre-commit .git/hooks/pre-push
    @echo "✓ All git hooks removed"

# ─── 清理 ──────────────────────────────────────

clean:
    cargo clean

clean-all: clean
    rm -rf target/

# ─── WASM ──────────────────────────────────────

wasm-test:
    cargo test -p pdf-wasm --target wasm32-unknown-unknown