//! Web routing scaffolding — domain-organized Router composition with Axum.
//!
//! # Pattern
//!
//! Each domain gets its own sub-router module:
//!
//! ```text
//! src/
//!   routes/
//!     mod.rs          → build_app_router() — composes all sub-routers
//!     health.rs       → GET  /health
//!     wiki.rs         → GET  /api/wiki/...
//!     auth.rs         → POST /api/auth/login, POST /api/auth/refresh
//!     admin.rs        → GET  /api/admin/...  (protected by AuthLayer)
//!     middleware/
//!       mod.rs        → re-exports all middleware
//!       auth.rs       → AuthLayer implementation
//!       metrics.rs    → MetricsLayer implementation
//!       request_id.rs → TraceLayer implementation
//!       cors.rs       → CorsLayer setup
//! ```
//!
//! # Usage
//!
//! ```ignore
//! let app = routes::build_app_router(state)
//!     .merge(metrics::metrics_router(metrics))
//!     .merge(api_doc::openapi_router());
//! ```

use axum::Router;

/// Application-level shared state.
///
/// Group all dependencies here so sub-routers can access them
/// uniformly via `State<Arc<AppState>>`.
#[derive(Clone)]
pub struct AppState {
    pub db_pool: sqlx::AnyPool,
    pub config: crate::config_loader::AppSettings,
    pub feature_flags: std::sync::Arc<crate::feature_flags::FeatureFlags>,
    pub upload_store: std::sync::Arc<crate::upload::UploadStore>,
}

pub fn build_app_router(state: AppState) -> Router {
    let shared_state = std::sync::Arc::new(state);

    Router::new()
        .merge(health::router())
        .merge(wiki::router(shared_state.clone()))
        .merge(auth::router(shared_state.clone()))
        .merge(admin::router(shared_state.clone()))
}

// ─── Sub-routers ────────────────────────────────────────────

mod health {
    use axum::{routing::get, Json, Router};
    use serde_json::{json, Value};

    pub fn router() -> Router {
        Router::new().route("/health", get(handler))
    }

    async fn handler() -> Json<Value> {
        Json(json!({"status": "ok", "version": env!("CARGO_PKG_VERSION")}))
    }
}

mod wiki {
    use super::AppState;
    use axum::{
        extract::{Path, Query, State},
        routing::get,
        Json, Router,
    };
    use serde::Deserialize;
    use std::sync::Arc;

    pub fn router(state: Arc<AppState>) -> Router {
        Router::new()
            .route("/api/wiki/search", get(search))
            .route("/api/wiki/entries/{*path}", get(entry))
            .with_state(state)
    }

    #[derive(Deserialize)]
    struct SearchQuery {
        q: String,
        #[serde(default = "default_limit")]
        limit: usize,
    }

    fn default_limit() -> usize {
        20
    }

    async fn search(
        State(_state): State<Arc<AppState>>,
        Query(_query): Query<SearchQuery>,
    ) -> Json<serde_json::Value> {
