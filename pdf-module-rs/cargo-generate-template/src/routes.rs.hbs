    use axum::{routing::post, Json, Router};
    use serde::Deserialize;
    use std::sync::Arc;

    pub fn router(state: Arc<AppState>) -> Router {
        Router::new()
            .route("/api/auth/login", post(login))
            .route("/api/auth/refresh", post(refresh))
            .with_state(state)
