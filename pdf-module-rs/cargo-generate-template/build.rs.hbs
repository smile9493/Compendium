//! Build script for code generation from `.proto` files.
//!
//! Automatically compiles protobuf definitions into Rust types
//! and optionally generates gRPC client/server code via tonic.
//!
//! # How to set up
//!
//! 1. Place `.proto` files in `proto/` directory
//! 2. Add dependencies:
//!    ```toml
//!    [build-dependencies]
//!    prost-build = "0.13"
//!    tonic-build = { version = "0.12", optional = true }
//!
//!    [dependencies]
//!    prost = "0.13"
//!    tonic = { version = "0.12", optional = true }
//!    ```
//! 3. This build.rs compiles on every `cargo build`
//!
//! # Features
//!
//! - `grpc` — also generate tonic gRPC client/server code

fn main() -> Result<(), Box<dyn std::error::Error>> {
    println!("cargo:rerun-if-changed=proto/");

    let mut config = prost_build::Config::new();
    config.type_attribute(".", "#[derive(serde::Serialize, serde::Deserialize)]");
    config.type_attribute(".", "#[serde(rename_all = \"snake_case\")]");

    #[cfg(feature = "grpc")]
    let server_config = tonic_build::configure()
        .build_server(true)
        .build_client(true)
        .type_attribute(".", "#[derive(serde::Serialize, serde::Deserialize)]");

    let proto_files = glob_proto("proto/")?;
    if proto_files.is_empty() {
        println!("cargo:warning=No .proto files found in proto/ — skipping codegen");
        return Ok(());
    }

    config.compile_protos(&proto_files, &["proto/"])?;

    #[cfg(feature = "grpc")]
    server_config.compile(&proto_files, &["proto/"])?;

    println!("cargo:rerun-if-changed=proto/");
    Ok(())
}

fn glob_proto(dir: &str) -> Result<Vec<String>, Box<dyn std::error::Error>> {
    let mut files = Vec::new();
    let dir_path = std::path::Path::new(dir);
    if !dir_path.exists() {
        return Ok(files);
    }
    for entry in std::fs::read_dir(dir_path)? {
        let entry = entry?;
        let path = entry.path();
        if path.extension().and_then(|s| s.to_str()) == Some("proto") {
            files.push(path.to_string_lossy().to_string());
        }
    }
    Ok(files)
}