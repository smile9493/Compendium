#!/usr/bin/env bash
# =============================================================================
# Git Pre-Commit Hook — 提交前代码质量检查
# =============================================================================
#
# 安装方式:
#   cp scripts/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit
#
# 此 hook 会在每次 git commit 前自动运行，检查：
#   1. 暂存区中所有 .rs 文件的格式化（rustfmt）
#   2. [可选] 全量质量检查（设置 GIT_HOOK_FULL_CHECK=1）
#
# 如果只想快速检查 fmt + clippy（跳过 test + doc + miri）：
#   GIT_HOOK_FULL_CHECK=1 git commit -m "..."
#
# 如果遇到紧急情况想跳过所有检查：
#   git commit --no-verify -m "..."
#
# =============================================================================

set -uo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

# 检查是否有暂存的 .rs 文件
STAGED_RS_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep '\.rs$' || true)

if [ -z "$STAGED_RS_FILES" ]; then
    echo -e "${CYAN}[pre-commit] 没有暂存的 Rust 文件，跳过检查。${NC}"
    exit 0
fi

echo -e "${CYAN}[pre-commit] 检测到 $(echo "$STAGED_RS_FILES" | wc -l) 个暂存的 Rust 文件${NC}"

# ---------------------------------------------------------------------------
# 检查 1: rustfmt — 仅检查暂存文件
# ---------------------------------------------------------------------------

echo -e "${CYAN}[pre-commit] ==> 检查暂存文件的格式化...${NC}"

UNFORMATTED=""
for file in $STAGED_RS_FILES; do
    if [ -f "$file" ]; then
        if ! rustfmt --check "$file" 2>/dev/null; then
            UNFORMATTED="$UNFORMATTED  $file\n"
        fi
    fi
done

if [ -n "$UNFORMATTED" ]; then
    echo -e "${RED}[pre-commit] ✗ 以下文件格式不规范:${NC}"
    echo -e "$UNFORMATTED"
    echo -e "${YELLOW}  修复命令: rustfmt <file>${NC}"
    echo -e "${YELLOW}  批量修复: echo \"\$STAGED_RS_FILES\" | xargs rustfmt${NC}"
    echo ""
    echo -e "${RED}提交已中止。请先格式化以上文件再重新提交。${NC}"
    exit 1
fi

echo -e "${GREEN}[pre-commit] ✓ 暂存文件格式化检查通过${NC}"

# ---------------------------------------------------------------------------
# 检查 2: 全量质量检查（可选）
# ---------------------------------------------------------------------------

if [ "${GIT_HOOK_FULL_CHECK:-0}" = "1" ]; then
    SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
    QUALITY_GUARD="$SCRIPT_DIR/quality-guard.sh"

    if [ -f "$QUALITY_GUARD" ]; then
        echo -e "${CYAN}[pre-commit] ==> 运行全量质量检查...${NC}"
        "$QUALITY_GUARD" --quick
        EXIT_CODE=$?
        if [ $EXIT_CODE -ne 0 ]; then
            echo -e "${RED}[pre-commit] ✗ 全量质量检查失败，提交已中止。${NC}"
            exit $EXIT_CODE
        fi
        echo -e "${GREEN}[pre-commit] ✓ 全量质量检查通过${NC}"
    else
        echo -e "${YELLOW}[pre-commit] 找不到 quality-guard.sh，跳过全量检查。${NC}"
    fi
else
    echo -e "${CYAN}[pre-commit] 提示: 设置 GIT_HOOK_FULL_CHECK=1 可启用 clippy+test+doc 全量检查${NC}"
fi

echo -e "${GREEN}[pre-commit] ✓ 全部检查通过，允许提交。${NC}"
exit 0